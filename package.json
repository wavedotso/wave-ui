{
  "name": "@waveso/ui",
  "version": "0.9.1",
  "description": "Wave UI component library built on Base UI and Tailwind CSS",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "keywords": [
    "react",
    "react-19",
    "ui",
    "components",
    "component-library",
    "design-system",
    "base-ui",
    "tailwindcss",
    "cva",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wavedotso/wave-ui.git"
  },
  "homepage": "https://github.com/wavedotso/wave-ui#readme",
  "bugs": "https://github.com/wavedotso/wave-ui/issues",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./package.json": "./package.json",
    "./styles.css": "./dist/styles.css",
    "./lib/*": null,
    "./hooks/*": null,
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check:package": "publint && attw --pack . --ignore-rules no-resolution",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "input-otp": "^1.4.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "input-otp": {
      "optional": true
    },
    "motion": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@base-ui/react": "^1.6.0",
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.27.0",
    "@storybook/addon-a11y": "~10.4.0",
    "@storybook/addon-docs": "~10.4.0",
    "@storybook/react-vite": "~10.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "jsdom": "^29.1.1",
    "motion": "^12.31.0",
    "publint": "^0.3.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "storybook": "~10.4.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.1",
    "tsdown": "0.21.10",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.7"
  }
}
